# ResumeForge Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# REQUIRED: JWT Secret for Authentication
# ============================================
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Or on Windows PowerShell: [System.BitConverter]::ToString([System.Security.Cryptography.RandomNumberGenerator]::GetBytes(32)).Replace('-','')
JWT_SECRET=your-secure-64-character-hex-string-here

# ============================================
# OPTIONAL: GitHub Token
# ============================================
# Only needed if you want to analyze private GitHub repositories
# Get from: https://github.com/settings/tokens
# Permissions needed: repo (read access)
GITHUB_TOKEN=

# ============================================
# OPTIONAL: Server Configuration
# ============================================
# Port the server will listen on (default: 3000)
PORT=3000

# Environment mode (development or production)
NODE_ENV=production

# ============================================
# OPTIONAL: Database Configuration
# ============================================
# Custom database path (default: ./resumeforge.db or /app/data/resumeforge.db in Docker)
# DB_PATH=/custom/path/to/database.db

# ============================================
# NOTES
# ============================================
# - Gemini API keys are NOT stored here - users provide them in the app Settings
# - Never commit .env file to version control
# - Use strong, unique JWT_SECRET in production
# - Rotate JWT_SECRET periodically for security
